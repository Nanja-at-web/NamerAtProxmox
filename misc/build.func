#!/usr/bin/env bash
# Branch-local build.func loader for the test branch.
#
# This is a stabilization step for the Variant-B migration:
# - loads upstream community-scripts build.func into a temporary local file
# - rewrites the relevant fetch URLs to this repository/branch
# - injects pre_install_hook support before the native installer stage
# - avoids the fragile source /dev/stdin string-wrapper approach

_BUILD_FUNC_TMP="$(mktemp /tmp/namer-build-func.XXXXXX)"

curl -fsSL \
  https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/build.func \
  -o "$_BUILD_FUNC_TMP"

perl -0pi -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/api.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/api.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/core.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/core.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/error_handler.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/error_handler.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/tools.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/tools.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/alpine-install.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/alpine-install.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/install.func#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/misc/install.func#g' \
  -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/install/\$\{var_install\}\.sh#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/install/\$\{var_install\}\.sh#g' \
  -e 's#\n    # Start timer for duration tracking#\n    if [[ \$install_exit_code -eq 0 ]] && declare -f pre_install_hook >/dev/null 2>&1; then\n      msg_info "Running pre-install hook"\n      if pre_install_hook; then\n        msg_ok "Pre-install hook completed"\n      else\n        \$install_exit_code=\$?\n        [[ \$install_exit_code -eq 0 ]] && \$install_exit_code=1\n        msg_error "pre_install_hook failed (exit code: \${install_exit_code})"\n      fi\n    fi\n\n    # Start timer for duration tracking#s' \
  "$_BUILD_FUNC_TMP"

source "$_BUILD_FUNC_TMP"
rm -f "$_BUILD_FUNC_TMP"
