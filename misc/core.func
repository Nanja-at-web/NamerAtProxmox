#!/usr/bin/env bash
# Branch-local core.func shim for the test branch.
#
# This is a staging step for the Variant-B migration:
# - functional fetch URLs and repository references are rewritten to this repository/branch
# - header fetches are redirected to the branch path
# - a full local fork can replace this shim in the next steps

source <(
  curl -fsSL https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/misc/core.func \
    | sed \
        -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/LICENSE#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/LICENSE#g' \
        -e 's#https://raw.githubusercontent.com/community-scripts/ProxmoxVE/main/${header_dir}/headers/${app_name}#https://raw.githubusercontent.com/Nanja-at-web/NamerAtProxmox/test/nfs-v1-autark-installer/${header_dir}/headers/${app_name}#g' \
        -e 's#https://github.com/community-scripts/ProxmoxVE#https://github.com/Nanja-at-web/NamerAtProxmox/tree/test/nfs-v1-autark-installer#g'
)
